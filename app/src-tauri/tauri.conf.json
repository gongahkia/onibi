{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Onibi",
  "version": "1.5.0-dev",
  "identifier": "sh.onibi.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Onibi",
        "width": 1400,
        "height": 900
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg", "appimage", "deb"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "__ONIBI_TAURI_UPDATER_PUBLIC_KEY__",
      "endpoints": [
        "https://github.com/gongahkia/onibi/releases/latest/download/latest.json"
      ]
    }
  }
}
